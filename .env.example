# ============================================================================
# aai — AI Agents Installer
# Copy this file to .env and fill in your values.
# The real .env file is gitignored and never committed.
# ============================================================================

# GitHub token (needed for private repos, gh CLI, and some agent features)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Provider API keys (used by agents inside their containers) -------------

# Anthropic (Claude Code, Hermes, Paperclip)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (Codex, GPT models)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google (Gemini CLI)
GOOGLE_API_KEY=

# --- Optional: OpenClaw gateway token --------------------------------------
# Required when exposing the gateway beyond localhost.
OPENCLAW_GATEWAY_TOKEN=

# --- Optional: GBrain embedding model --------------------------------------
# Configure after install: docker compose exec gbrain gbrain config set embedding_model <id>
# GBRAIN_EMBEDDING_MODEL=
